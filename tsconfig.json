{
    "include": ["src"],
    "compilerOptions": {
        "target": "ES2020",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "paths": {
            "@/*": ["./src/*"],
            "@app-api/*": ["./src/api/*"],
            "@app-components/*": ["./src/components/*"],
            "@app-consts/*": ["./src/consts/*"],
            "@app-context/*": ["./src/context/*"],
            "@app-hooks/*": ["./src/hooks/*"],
            "@app-store/*": ["./src/store/*"],
            "@app-types/*": ["./src/types/*"],
            "@app-ui/*": ["./src/ui/*"],
            "@app-utils/*": ["./src/utils/*"],
        },
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
    },
}
